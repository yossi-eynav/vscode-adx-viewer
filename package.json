{
  "name": "adx-vscode-viewer",
  "displayName": "ADX Query Viewer",
  "description": "View Azure Data Explorer KQL query results directly in VS Code",
  "version": "0.1.0",
  "publisher": "adx-vscode-viewer",
  "engines": {
    "vscode": "^1.74.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:kusto"
  ],
  "contributes": {
    "commands": [
      {
        "command": "adxViewer.configureCredentials",
        "title": "ADX: Add / Edit Connection"
      },
      {
        "command": "adxViewer.switchConnection",
        "title": "ADX: Switch Connection"
      },
      {
        "command": "adxViewer.openViewer",
        "title": "ADX: Open Query Results",
        "icon": "$(run)"
      },
      {
        "command": "adxViewer.showGraph",
        "title": "ADX: Show Graph",
        "icon": "$(graph-line)"
      },
      {
        "command": "adxViewer.defineVariable",
        "title": "ADX: Define Query Variable"
      },
      {
        "command": "adxViewer.configureVariable",
        "title": "ADX: Configure Query Variable"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "adxViewer.openViewer",
          "when": "resourceExtname == .kusto",
          "group": "navigation@1"
        },
        {
          "command": "adxViewer.showGraph",
          "when": "resourceExtname == .kusto",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "ADX Query Viewer",
      "properties": {}
    },
    "languages": [
      {
        "id": "kusto",
        "aliases": [
          "Kusto",
          "Kusto Query Language"
        ],
        "extensions": [
          ".kusto"
        ]
      }
    ]
  },
  "scripts": {
    "compile": "webpack",
    "watch": "webpack --watch",
    "build": "webpack --mode production",
    "webview:dev": "webpack serve --config webpack.webview.js",
    "webview:build": "webpack --config webpack.webview.js --mode production",
    "webview:fetch": "ts-node --project tsconfig.json scripts/fetchMockData.ts",
    "package": "vsce package",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.config.js",
    "test:integration": "node ./out/tests/integration/runTests.js",
    "lint": "eslint src --ext .ts",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-json-view": "^2.0.0-alpha.41",
    "azure-kusto-data": "^7.0.0",
    "chart.js": "^4.5.1",
    "process": "^0.11.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
