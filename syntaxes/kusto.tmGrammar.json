{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kusto Query Language",
  "scopeName": "source.kusto",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#timespan-literals" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#statement-keywords" },
    { "include": "#pipe" },
    { "include": "#tabular-operators" },
    { "include": "#aggregation-functions" },
    { "include": "#scalar-functions" },
    { "include": "#string-operators" },
    { "include": "#logical-operators" },
    { "include": "#clause-keywords" },
    { "include": "#type-names" },
    { "include": "#operators" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.double-slash.kusto",
      "match": "//.*$"
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kusto",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.kusto", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.single.kusto",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.kusto", "match": "\\\\." }]
        },
        {
          "name": "string.quoted.verbatim.kusto",
          "begin": "@\"",
          "end": "\"",
          "comment": "Verbatim double-quoted string — no escape sequences"
        },
        {
          "name": "string.quoted.verbatim.kusto",
          "begin": "@'",
          "end": "'",
          "comment": "Verbatim single-quoted string — no escape sequences"
        },
        {
          "name": "string.quoted.triple.kusto",
          "begin": "```",
          "end": "```",
          "comment": "Multi-line string literal"
        }
      ]
    },

    "timespan-literals": {
      "comment": "Timespan suffixes: 1d, 2h, 30m, 15s, 100ms, 1us, 1tick",
      "name": "constant.numeric.timespan.kusto",
      "match": "\\b\\d+(\\.\\d+)?\\s*(d|h|m|s|ms|microsecond|tick)\\b"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kusto",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.kusto",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },

    "constants": {
      "name": "constant.language.kusto",
      "match": "\\b(true|false|null)\\b"
    },

    "statement-keywords": {
      "patterns": [
        {
          "name": "keyword.control.let.kusto",
          "match": "\\blet\\b"
        },
        {
          "name": "keyword.other.kusto",
          "match": "\\b(set|declare)\\b"
        }
      ]
    },

    "pipe": {
      "name": "keyword.operator.pipe.kusto",
      "match": "\\|"
    },

    "tabular-operators": {
      "name": "keyword.control.kusto",
      "match": "\\b(where|summarize|project|project-away|project-rename|project-reorder|extend|join|union|take|limit|top|top-nested|sort|order|distinct|count|search|parse|parse-where|parse-kv|mv-expand|mv-apply|evaluate|render|make-series|invoke|getschema|sample|sample-distinct|reduce|as|fork|facet|print|datatable|range|externaldata|consume|serialize|partition|lookup|aggregate)\\b"
    },

    "aggregation-functions": {
      "name": "support.function.aggregate.kusto",
      "match": "\\b(sum|sumif|avg|avgif|min|minif|max|maxif|count|countif|dcount|dcountif|any|anyif|arg_max|arg_min|make_list|make_list_if|make_list_with_nulls|make_set|make_set_if|percentile|percentiles|percentile_tdigest|percentiles_array|stdev|stdevif|stdevp|variancep|variance|varianceif|hll|hll_merge|tdigest|tdigest_merge|buildschema|take_any|take_anyif|bag_unpack)\\b(?=\\s*\\()"
    },

    "scalar-functions": {
      "name": "support.function.scalar.kusto",
      "match": "\\b(ago|now|bin|bin_at|floor|ceiling|round|abs|sqrt|log|log2|log10|exp|exp2|exp10|pow|sign|pi|gamma|loggamma|min_of|max_of|coalesce|iif|iff|case|zip|datetime|todatetime|totimespan|format_datetime|format_timespan|datetime_add|datetime_part|datetime_diff|endofday|endofweek|endofmonth|endofyear|startofday|startofweek|startofmonth|startofyear|weekofyear|dayofweek|dayofmonth|dayofyear|monthofyear|hourofday|getyear|getmonth|array_length|array_concat|array_slice|array_sum|array_rotate_left|array_rotate_right|array_reverse|array_sort_asc|array_sort_desc|array_split|array_index_of|array_iif|pack|pack_all|pack_array|bag_keys|bag_values|bag_merge|bag_remove_keys|bag_pack|bag_has_key|extract|extract_all|extractjson|parse_json|parse_xml|parse_csv|parse_url|parse_urlquery|parse_path|parse_ipv4|parse_ipv4_mask|parse_ipv6|parse_ipv6_mask|tostring|toint|tolong|todouble|tobool|toguid|todynamic|tohex|tobase64|tounicode|frombase64|strlen|strcat|strcat_array|strcat_delim|substring|split|trim|trim_start|trim_end|trim_chars|toupper|tolower|replace|replace_regex|replace_string|replace_strings|translate|indexof|indexof_regex|countof|url_encode|url_decode|base64_encode_tostring|base64_decode_tostring|base64_decode_toarray|hash|hash_sha256|hash_md5|hash_xxhash64|hash_combine|isnan|isinf|isfinite|isempty|isnotempty|isnull|isnotnull|ingestion_time|cursor_current|cursor_after|cursor_before_or_at|series_stats|series_stats_dynamic|series_fill_linear|series_fill_const|series_fill_backward|series_fill_forward|series_fir|series_iir|series_fit_line|series_fit_poly|series_outliers|series_periods_detect|series_periods_validate|series_seasonal|series_add|series_subtract|series_multiply|series_divide|series_sum|series_product|geo_point_to_geohash|geo_geohash_to_central_point|geo_distance_2points|geo_distance_point_to_line|geo_point_in_circle|geo_point_in_polygon|geo_polygon_to_s2cells|ipv4_is_match|ipv4_compare|ipv4_is_in_range|ipv4_is_private|ipv6_is_match|ipv6_compare|format_bytes|print_schema|typeof)\\b(?=\\s*\\()"
    },

    "string-operators": {
      "name": "keyword.operator.word.kusto",
      "match": "\\b(has|has_cs|has_any|has_all|hasprefix|hasprefix_cs|hassuffix|hassuffix_cs|contains|contains_cs|notcontains|notcontains_cs|startswith|startswith_cs|endswith|endswith_cs|matches|regex|in~|!in~|in|!in|between|!between)\\b"
    },

    "logical-operators": {
      "name": "keyword.operator.logical.kusto",
      "match": "\\b(and|or|not)\\b"
    },

    "clause-keywords": {
      "name": "keyword.other.clause.kusto",
      "match": "\\b(by|on|with|asc|desc|nulls|first|last|kind|inner|outer|left|right|fullouter|innerunique|anti|leftanti|leftantisemi|rightsemi|rightantisemi|leftouter|rightouter|of|typeof|toscalar|materialize|single|cluster|database)\\b"
    },

    "type-names": {
      "name": "storage.type.kusto",
      "match": "\\b(string|int|long|real|double|decimal|bool|boolean|datetime|timespan|dynamic|guid|uniqueid)\\b"
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.kusto",
          "match": "(==|!=|=~|!~|<>|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.kusto",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.kusto",
          "match": "[+\\-*/%]"
        }
      ]
    }
  }
}
